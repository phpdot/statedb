{
  "name": "@phpdot/statedb",
  "version": "1.0.0",
  "description": "Lightweight, zero-dependency reactive database for JavaScript and TypeScript. MongoDB-style queries, update operators, indexes, schema validation, and a built-in watcher system for real-time UI reactivity. Optional localStorage/sessionStorage persistence. Ships as ESM, CJS, and IIFE.",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsup --watch",
    "bench": "npx tsx benchmarks/bench.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "database",
    "reactive",
    "mongodb",
    "browser",
    "localStorage",
    "in-memory",
    "state-management"
  ],
  "author": "Omar Hamdan <omar@phpdot.com>",
  "license": "MIT",
  "homepage": "https://github.com/phpdot/statedb#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phpdot/statedb.git"
  },
  "bugs": {
    "url": "https://github.com/phpdot/statedb/issues"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "sideEffects": false
}
